// ════════════════════════════════════════════════════════════════
//  STORAGE  (all keys prefixed dg_)
// ════════════════════════════════════════════════════════════════
const LS = {
  get:   (k, d = null) => { try { const v = localStorage.getItem(`dg_${k}`); return v !== null ? JSON.parse(v) : d; } catch { return d; } },
  set:   (k, v)        => { try { localStorage.setItem(`dg_${k}`, JSON.stringify(v)); } catch {} },
  del:   (k)           => { try { localStorage.removeItem(`dg_${k}`); } catch {} },
  clear: ()            => { ["start","solved","lockout","lockoutClue","timers","disabled"].forEach(k => LS.del(k)); sessionStorage.removeItem("dg_intro"); },
};

